---
const year = new Date().getFullYear();
---

<footer class="bg-primary text-white/80 px-4 md:px-10 py-12">
  <div class="max-w-[1200px] mx-auto grid grid-cols-1 md:grid-cols-4 gap-10">
    <div class="flex flex-col gap-3">
      <div class="flex items-center gap-3 text-white">
        <div class="size-6">
          <svg fill="none" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg">
            <path d="M4 4H17.3334V17.3334H30.6666V30.6666H44V44H4V4Z" fill="currentColor"></path>
          </svg>
        </div>
        <span class="font-h2 text-lg font-bold">Gesergas</span>
      </div>
      <p class="text-sm leading-relaxed">
        Instalación y mantenimiento de calderas, climatización y energías renovables en Valladolid.
      </p>
    </div>

    <div>
      <h4 class="font-h3 text-white font-bold mb-3">Servicios</h4>
      <ul class="flex flex-col gap-2 text-sm">
        <li><a href="/calderas" class="hover:text-white">Calderas de gas</a></li>
        <li><a href="/aire-acondicionado" class="hover:text-white">Aire acondicionado</a></li>
        <li><a href="/aerotermia" class="hover:text-white">Aerotermia</a></li>
        <li><a href="/suelo-radiante" class="hover:text-white">Suelo radiante</a></li>
        <li><a href="/placas-solares" class="hover:text-white">Placas solares</a></li>
        <li><a href="/fontaneria" class="hover:text-white">Fontanería</a></li>
        <li><a href="/naturgy" class="hover:text-white">Atención Naturgy</a></li>
      </ul>
    </div>

    <div>
      <h4 class="font-h3 text-white font-bold mb-3">Contacto</h4>
      <ul class="flex flex-col gap-2 text-sm">
        <li><a href="tel:983218630" class="hover:text-white">983 21 86 30</a></li>
        <li><a href="mailto:contacto@gesergas.net" class="hover:text-white">contacto@gesergas.net</a></li>
        <li>Plaza San Juan, Valladolid</li>
        <li>L-V 9:00 – 18:00</li>
      </ul>
    </div>

    <div>
      <h4 class="font-h3 text-white font-bold mb-3">Legal</h4>
      <ul class="flex flex-col gap-2 text-sm">
        <li><a href="/politica-privacidad" class="hover:text-white">Política de privacidad</a></li>
        <li><a href="/politica-cookies" class="hover:text-white">Política de cookies</a></li>
        <li><a href="/aviso-legal" class="hover:text-white">Aviso legal</a></li>
      </ul>
    </div>
  </div>

  <div class="max-w-[1200px] mx-auto border-t border-white/10 mt-10 pt-6 text-xs text-white/60 flex flex-col sm:flex-row justify-between gap-2">
    <span>© {year} Gesergas. Todos los derechos reservados.</span>
    <span>Hecho con cariño en Valladolid.</span>
  </div>
</footer>
