---
export interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  image: string;
  imageAlt?: string;
}

const { eyebrow, title, subtitle, image, imageAlt = '' } = Astro.props;
---

<section class="px-4 md:px-10 pt-10 pb-xxl">
  <div class="max-w-[1200px] mx-auto grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
    <div class="flex flex-col gap-5">
      {eyebrow && (
        <span class="font-label-caps text-secondary-container">{eyebrow}</span>
      )}
      <h1 class="font-h1 text-4xl md:text-5xl lg:text-6xl font-black text-on-surface leading-[1.05] tracking-[-0.02em]">
        {title}
      </h1>
      {subtitle && (
        <p class="text-body-lg text-on-surface-variant leading-relaxed max-w-[560px]">{subtitle}</p>
      )}
      <div class="flex flex-wrap gap-3 mt-2">
        <a
          href="/contacto"
          class="inline-flex items-center justify-center rounded-full h-12 px-7 bg-secondary-container text-on-secondary-container font-bold text-sm hover:bg-secondary hover:text-white transition-colors shadow-md"
        >
          Solicitar presupuesto
        </a>
        <a
          href="tel:983218630"
          class="inline-flex items-center gap-2 justify-center rounded-full h-12 px-7 bg-surface-container-lowest border border-outline-variant text-on-surface font-bold text-sm hover:border-primary-container transition-colors"
        >
          <span class="material-symbols-outlined text-[20px]">call</span> 983 21 86 30
        </a>
      </div>
    </div>

    <div class="relative">
      <div class="absolute -inset-6 bg-primary-fixed/40 rounded-[40px] -z-10 blur-2xl"></div>
      <img
        src={image}
        alt={imageAlt}
        loading="eager"
        class="w-full h-auto rounded-3xl shadow-xl object-cover aspect-[3/2] border border-outline-variant/30"
      />
    </div>
  </div>
</section>
