---
---

<section id="analiza-factura" class="px-4 md:px-10 py-xxl bg-surface-container-low">
  <div class="max-w-[1100px] mx-auto">
    <div class="text-center mb-xl">
      <span class="font-label-caps text-secondary-container">AHORRO GARANTIZADO</span>
      <h2 class="font-h2 text-h2 text-on-surface mt-2 mb-3">
        Analizamos tu factura gratis
      </h2>
      <p class="text-body-lg text-on-surface-variant max-w-[600px] mx-auto">
        Súbenos tu última factura de gas o luz y te decimos exactamente cuánto puedes ahorrar. Sin compromiso.
      </p>
    </div>

    <div class="bg-surface-container-lowest rounded-3xl border border-outline-variant/40 shadow-md overflow-hidden grid grid-cols-1 lg:grid-cols-2">

      <!-- Columna izquierda: beneficios -->
      <div class="bg-primary-container text-on-primary p-8 md:p-10 flex flex-col gap-6 justify-center">
        <h3 class="font-h2 text-2xl font-bold leading-snug">¿Qué incluye el análisis?</h3>
        <ul class="flex flex-col gap-4 text-sm">
          <li class="flex items-start gap-3">
            <span class="mt-0.5 w-6 h-6 rounded-full bg-white/20 flex items-center justify-center font-bold flex-shrink-0">1</span>
            <span>Revisamos tu tarifa actual y la comparamos con las mejores opciones del mercado.</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="mt-0.5 w-6 h-6 rounded-full bg-white/20 flex items-center justify-center font-bold flex-shrink-0">2</span>
            <span>Detectamos consumos anómalos que pueden indicar fugas o equipos ineficientes.</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="mt-0.5 w-6 h-6 rounded-full bg-white/20 flex items-center justify-center font-bold flex-shrink-0">3</span>
            <span>Te llamamos con un informe claro y recomendaciones sin letra pequeña.</span>
          </li>
        </ul>
        <p class="text-xs text-on-primary/60 mt-2">Tu factura se trata de forma confidencial y solo se usa para el análisis.</p>
      </div>

      <!-- Columna derecha: formulario -->
      <div class="p-8 md:p-10">
        <form
          id="factura-form"
          class="flex flex-col gap-5"
          enctype="multipart/form-data"
          method="post"
          action="#"
          novalidate
        >
          <label class="flex flex-col gap-1 text-sm font-semibold text-on-surface">
            Nombre *
            <input
              type="text"
              name="nombre"
              required
              placeholder="Tu nombre y apellidos"
              class="h-12 px-4 rounded-xl border border-outline-variant bg-surface-container focus:border-primary-container focus:ring-2 focus:ring-primary-container/20 outline-none transition"
            />
          </label>

          <label class="flex flex-col gap-1 text-sm font-semibold text-on-surface">
            Teléfono *
            <input
              type="tel"
              name="telefono"
              required
              placeholder="600 123 456"
              pattern="[0-9\s\+\-]{9,15}"
              class="h-12 px-4 rounded-xl border border-outline-variant bg-surface-container focus:border-primary-container focus:ring-2 focus:ring-primary-container/20 outline-none transition"
            />
          </label>

          <label class="flex flex-col gap-2 text-sm font-semibold text-on-surface">
            Factura (PDF, JPG o PNG) *
            <div
              id="drop-zone"
              class="relative flex flex-col items-center justify-center gap-2 rounded-2xl border-2 border-dashed border-outline-variant bg-surface-container hover:border-primary-container hover:bg-primary-fixed/30 transition-colors cursor-pointer px-6 py-8 text-center"
            >
              <span class="material-symbols-outlined text-[36px] text-on-surface-variant">upload_file</span>
              <span class="text-sm text-on-surface-variant">
                Arrastra aquí tu factura o <span class="text-primary-container font-bold underline">selecciona archivo</span>
              </span>
              <span class="text-xs text-on-surface-variant/60">PDF, JPG o PNG · Máx. 10 MB</span>
              <input
                type="file"
                name="factura"
                id="factura-input"
                required
                accept=".pdf,.jpg,.jpeg,.png"
                class="absolute inset-0 opacity-0 cursor-pointer"
              />
            </div>
            <p id="file-name" class="text-xs text-primary-container font-medium hidden"></p>
          </label>

          <label class="flex items-start gap-2 text-xs text-on-surface-variant">
            <input type="checkbox" required class="mt-0.5 rounded border-outline-variant" />
            <span>Acepto la <a href="#" class="underline">política de privacidad</a> y el tratamiento de mis datos para recibir el análisis.</span>
          </label>

          <button
            type="submit"
            class="h-12 rounded-full bg-primary-container text-on-primary font-bold text-sm uppercase tracking-wide hover:bg-primary transition-colors"
          >
            Enviar factura para análisis gratuito
          </button>

          <p id="form-success" class="hidden text-sm text-center font-semibold text-primary-container bg-primary-fixed/40 rounded-xl px-4 py-3">
            ¡Recibido! Te llamamos en menos de 24 h con tu análisis.
          </p>
        </form>
      </div>
    </div>
  </div>
</section>

<script>
  const input = document.getElementById('factura-input') as HTMLInputElement | null;
  const label = document.getElementById('file-name');
  const dropZone = document.getElementById('drop-zone');

  input?.addEventListener('change', () => {
    const file = input.files?.[0];
    if (file && label) {
      label.textContent = `Archivo seleccionado: ${file.name}`;
      label.classList.remove('hidden');
    }
  });

  // Feedback visual al arrastrar
  dropZone?.addEventListener('dragover', (e) => {
    e.preventDefault();
    dropZone.classList.add('border-primary-container', 'bg-primary-fixed/30');
  });
  dropZone?.addEventListener('dragleave', () => {
    dropZone.classList.remove('border-primary-container', 'bg-primary-fixed/30');
  });
  dropZone?.addEventListener('drop', (e) => {
    e.preventDefault();
    dropZone.classList.remove('border-primary-container', 'bg-primary-fixed/30');
    const file = e.dataTransfer?.files[0];
    if (file && input && label) {
      const dt = new DataTransfer();
      dt.items.add(file);
      input.files = dt.files;
      label.textContent = `Archivo seleccionado: ${file.name}`;
      label.classList.remove('hidden');
    }
  });

  // Simular submit (conectar al backend real cuando esté disponible)
  document.getElementById('factura-form')?.addEventListener('submit', (e) => {
    e.preventDefault();
    const success = document.getElementById('form-success');
    const btn = e.currentTarget as HTMLFormElement;
    btn.querySelector('button[type="submit"]')?.setAttribute('disabled', 'true');
    success?.classList.remove('hidden');
  });
</script>
