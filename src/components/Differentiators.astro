---
const items = [
  {
    icon: 'euro_symbol',
    title: 'Precios cerrados sin sorpresas',
    text: 'El presupuesto que apruebas es el precio final. Sin cargos ocultos.',
  },
  {
    icon: 'engineering',
    title: 'Técnicos propios certificados',
    text: 'Personal en plantilla con certificación RITE. Nada de subcontratas.',
  },
  {
    icon: 'description',
    title: 'Gestión de subvenciones',
    text: 'Tramitamos el Plan Renove y otras ayudas autonómicas por ti.',
  },
  {
    icon: 'shield',
    title: '3 años de garantía*',
    text: 'Garantía oficial de fabricante y servicio postventa propio.',
    footnote: 'Ampliable a 5 años con el contrato de ampliación de garantía Naturgy.',
  },
];
---

<section class="px-4 md:px-10 py-xxl">
  <div class="max-w-[1200px] mx-auto">
    <div class="text-center mb-xl">
      <span class="font-label-caps text-secondary-container">¿POR QUÉ NOSOTROS?</span>
      <h2 class="font-h2 text-h2 text-on-surface mt-2">Razones para confiar en Gesergas</h2>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {items.map((it) => (
        <div class="flex flex-col items-start gap-3 p-6 rounded-2xl border border-outline-variant/40 bg-surface-container-lowest">
          <div class="w-14 h-14 rounded-full bg-primary-container/10 flex items-center justify-center text-primary-container">
            <span class="material-symbols-outlined text-[28px]">{it.icon}</span>
          </div>
          <h3 class="font-h3 text-lg font-bold text-on-surface">{it.title}</h3>
          <p class="text-on-surface-variant text-sm leading-relaxed">{it.text}</p>
          {it.footnote && (
            <p class="text-on-surface-variant/60 text-xs leading-relaxed border-t border-outline-variant/30 pt-2 mt-1">
              *{it.footnote}
            </p>
          )}
        </div>
      ))}
    </div>
  </div>
</section>
